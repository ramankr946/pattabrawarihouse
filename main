      <div class="kitchen-diagram">
        <svg viewBox="0 0 700 250" role="img" aria-label="Indicative modern support kitchen without central island">
          <rect x="20" y="20" width="660" height="210" rx="14" fill="#fffaf2" stroke="#ddcfbc" stroke-width="3"/>
