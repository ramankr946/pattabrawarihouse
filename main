def fig(key, title, caption=""):
    if key not in imgs:
        return ""
    return f"""
      <figure class="ref-card">
        <img src="{imgs[key]}" alt="{html_lib.escape(title)}">
        <figcaption><strong>{html_lib.escape(title)}</strong><span>{html_lib.escape(caption)}</span></figcaption>
      </figure>
    """

